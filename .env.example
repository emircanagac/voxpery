# Voxpery — copy to .env in repo root. Single source of truth for Docker, backend and frontend.

# ==============================================================================
# 1. DOCKER & INFRASTRUCTURE
# ==============================================================================

## Database credentials (PostgreSQL)
POSTGRES_USER=voxpery
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=voxpery

## Docker host port bindings
WEB_PORT=5173
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

## Optional prebuilt app images (production deploys can override these)
# VOXPERY_SERVER_IMAGE=voxpery/voxpery-server:latest
# VOXPERY_WEB_IMAGE=voxpery/voxpery-web:latest

## LiveKit (SFU): used by Docker Compose and backend token minting.
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=CHANGE_ME_TO_A_STRONG_32_PLUS_CHAR_SECRET
# LiveKit public IPv4 for production (leave empty in local/dev)
LIVEKIT_NODE_IP=
# Optional (production hardening; leave unset for no limits)
# LIVEKIT_CPUS_LIMIT=4.0
# LIVEKIT_MEM_LIMIT=3g
# LIVEKIT_PIDS_LIMIT=1024


# ==============================================================================
# 2. FRONTEND (apps/web)
# ==============================================================================

## API base URL. Use localhost in dev so OAuth and cookies work with backend.
VITE_API_URL=http://localhost:3001


# ==============================================================================
# 3. BACKEND (apps/server)
# ==============================================================================

## Log level: info (default), debug or trace.
RUST_LOG=info

## Database connections (Docker Compose network / container-native)
DATABASE_URL=postgres://voxpery:YOUR_POSTGRES_PASSWORD@postgres:5432/voxpery
REDIS_URL=redis://redis:6379

## Server bindings and JWT Security
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRATION=86400

## Allowed frontend origins (comma separated).
CORS_ORIGINS=http://localhost:5173,tauri://localhost,voxpery://auth

## Rate Limiting (General)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECS=60
LOGIN_FAILURE_MAX_ATTEMPTS=8
LOGIN_FAILURE_IP_MAX_ATTEMPTS=20
LOGIN_FAILURE_WINDOW_SECS=900
MESSAGE_RATE_LIMIT_MAX=30
MESSAGE_RATE_LIMIT_WINDOW_SECS=10

## Initial admin user (required for first setup / bootstrap).
ADMIN_EMAIL=admin@local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

## Cookie Security
## Prod: set COOKIE_SECURE=1 (HTTPS). Dev (HTTP): 0 or unset so OAuth CSRF cookie works.
COOKIE_SECURE=0
AUTH_COOKIE_NAME=voxpery_token

## Attachments (message/DM uploads)
ATTACHMENTS_LOCAL_DIR=./storage/attachments
ATTACHMENTS_KEY_PREFIX=attachments
ATTACHMENTS_PUBLIC_BASE_URL=http://localhost:3001
ATTACHMENTS_MAX_FILE_BYTES=5242880
ATTACHMENTS_MAX_FILES_PER_REQUEST=4
ATTACHMENTS_ALLOWED_MIME_PREFIXES=image/,video/,audio/,application/pdf,text/plain,application/zip
ATTACHMENTS_URL_TTL_SECS=900
ATTACHMENTS_CLAMAV_ENABLED=1
ATTACHMENTS_CLAMAV_FAIL_CLOSED=1
ATTACHMENTS_CLAMAV_HOST=clamav
ATTACHMENTS_CLAMAV_PORT=3310
ATTACHMENTS_CLAMAV_TIMEOUT_MS=5000


# ==============================================================================
# 4. OPTIONAL INTEGRATIONS (Uncomment to enable)
# ==============================================================================

## TURN Server (WebRTC). Only needed for voice across restrictive corporate networks.
# TURN_URLS=
# TURN_SHARED_SECRET=CHANGE_ME_TO_A_STRONG_TURN_SECRET
# TURN_CREDENTIAL_TTL_SECS=3600

## Cloudflare Turnstile CAPTCHA (Bot protection on registration).
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

## Google OAuth ("Continue with Google").
## Redirect URI: http://localhost:3001/api/auth/google/callback (dev) or https://your-api... (prod).
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# PUBLIC_API_URL=http://localhost:3001

## SMTP Configuration (Password Reset)
## Provider examples: smtp.gmail.com (port 587/465 is handled by lettre with STARTTLS/TLS automatically)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
