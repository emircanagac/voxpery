# Voxpery Unified Environment Variables
# Single source of truth for Docker + Backend + Frontend.
# Copy this file to .env in repository root.

# ============================================================
# Docker Compose / Infrastructure
# ============================================================
POSTGRES_USER=voxpery
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=voxpery

# LiveKit (SFU): used by Docker Compose and backend token minting
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=CHANGE_ME_TO_A_STRONG_32_PLUS_CHAR_SECRET

# ============================================================
# Backend (apps/server)
# ============================================================
# Optional: Set log level (trace, debug, info, warn, error). 
# Default is info. Use 'debug' or 'trace' for deep debugging.
# RUST_LOG=info

# Must use the same password as POSTGRES_PASSWORD above.
DATABASE_URL=postgres://voxpery:YOUR_POSTGRES_PASSWORD@localhost:5432/voxpery
REDIS_URL=redis://localhost:6379

JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRATION=86400
SERVER_HOST=0.0.0.0
SERVER_PORT=3001

# Production: set explicitly and avoid defaults.
# Add null only if required for Tauri desktop release behavior.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost

AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECS=60
MESSAGE_RATE_LIMIT_MAX=30
MESSAGE_RATE_LIMIT_WINDOW_SECS=10

# TURN (coturn use_auth_secret)
# Optional: leave TURN_* empty if TURN is not configured.
# Example: TURN_URLS=turn:turn.your-domain.com:3478?transport=udp,turns:turn.your-domain.com:5349?transport=tcp
# TURN_SHARED_SECRET must match coturn static-auth-secret
TURN_URLS=
TURN_SHARED_SECRET=CHANGE_ME_TO_A_STRONG_TURN_SECRET
TURN_CREDENTIAL_TTL_SECS=3600

# Optional seed admin (dev/bootstrap only)
ADMIN_EMAIL=admin@local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Optional auth cookie settings
# COOKIE_SECURE=0
# AUTH_COOKIE_NAME=voxpery_token

# Optional: Google OAuth (Sign in with Google). If unset, "Continue with Google" returns 503.
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/ and set redirect URI to:
#   http://127.0.0.1:3001/api/auth/google/callback   (dev) or https://your-api-domain/api/auth/google/callback (prod)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# PUBLIC_API_URL must match the base URL of this server. In dev use same host as frontend (e.g. localhost) so the auth cookie is sent after Google login.
# PUBLIC_API_URL=http://localhost:3001

# ============================================================
# Frontend (apps/web)
# ============================================================
VITE_API_URL=http://127.0.0.1:3001
